{
  "name": "rose-dev-ide",
  "version": "2.0.61",
  "description": "rose.dev AI IDE - Premium Code Editor with AI Integration",
  "author": {
    "name": "EliussRose",
    "email": "eliussksa@gmail.com",
    "url": "https://ghury.com"
  },
  "company": "Prosinres",
  "homepage": "https://github.com/eliussrose/rose-dev-ide",
  "repository": {
    "type": "git",
    "url": "https://github.com/eliussrose/rose.dev.git"
  },
  "bugs": {
    "url": "https://github.com/eliussrose/rose.dev/issues",
    "email": "eliussksa@gmail.com"
  },
  "main": "electron.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/version-bump.js && next build",
    "start": "next start",
    "lint": "eslint",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "node scripts/version-bump.js && next build && node scripts/copy-standalone-deps.js && electron-builder",
    "electron:build:win": "node scripts/bundle-node-windows.js && node scripts/version-bump.js && next build && node scripts/copy-standalone-deps.js && electron-builder --win",
    "electron:build:mac": "node scripts/version-bump.js && next build && node scripts/copy-standalone-deps.js && electron-builder --mac",
    "electron:build:linux": "node scripts/version-bump.js && next build && node scripts/copy-standalone-deps.js && electron-builder --linux",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "version:bump": "node scripts/version-bump.js",
    "version:reset": "node scripts/version-reset.js",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:win": "tauri build --target x86_64-pc-windows-msvc"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.15",
    "@monaco-editor/react": "^4.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "monaco-languageclient": "^8.1.1",
    "next": "^15.5.15",
    "pyright": "^1.1.350",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "tailwind-merge": "^3.5.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-ws-jsonrpc": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^7.2.0"
  }
}
