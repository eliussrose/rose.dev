{
  "appId": "com.prosinres.rosedev.ide",
  "productName": "rose.dev-AI-IDE",
  "copyright": "Copyright © 2026 Prosinres. All rights reserved.",
  "directories": {
    "output": "build",
    "buildResources": "public"
  },
  "files": [
    "electron.js",
    "preload.js",
    ".next/standalone/**/*",
    ".next/static/**/*",
    "public/**/*",
    "package.json",
    "node_modules/.pnpm/**/*",
    "!node_modules/.pnpm/**/node_modules",
    "!**/*.map",
    "!.next/cache/**/*"
  ],
  "extraResources": [
    {
      "from": "resources/node.exe",
      "to": "node.exe",
      "filter": ["**/*"]
    }
  ],
  "asarUnpack": [
    ".next/**/*",
    "node_modules/**/*"
  ],
  "win": {
    "target": [
      { "target": "dir", "arch": ["x64"] }
    ],
    "artifactName": "rose.dev-AI-IDE-Setup-${version}.${ext}"
  },
  "mac": {
    "target": ["dmg"],
    "icon": "public/icon.png",
    "category": "public.app-category.developer-tools",
    "artifactName": "rose.dev-AI-IDE-${version}.${ext}"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "icon": "public/icon.png",
    "category": "Development",
    "artifactName": "rose.dev-AI-IDE-${version}.${ext}"
  },
  "extraMetadata": {
    "main": "electron.js"
  }
}
